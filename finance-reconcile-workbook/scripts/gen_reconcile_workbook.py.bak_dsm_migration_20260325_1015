#!/usr/bin/env python3
"""Generate 吉众对账“匹配模板”工作表（A/B 双口径）并上传到 Nextcloud。

- A：银行/现金实际出账（银行/现金 sheet 贷方合计）
- B：凭证/发票口径（用于与发票金额勾稽：扣手续费 + 可包含挂应付）

This script uses:
- system python: requests + openpyxl
- xlrd extraction via workspace venv `.venv-xls` (calls `extract_finance_xls.py`)

It reads creds from `secure/api-fillin.env`:
- NEXTCLOUD_URL/NEXTCLOUD_USER/NEXTCLOUD_PASS
- ERP_BASE_URL/ERP_API_TOKEN

Outputs:
- 匹配模板_<YYYYMM>_自动填充_v3_AB_含规格备注.xlsx

Safety:
- Read-only to ERPNext (no writes, no Payment Entry submit).
"""

from __future__ import annotations

import argparse
import csv
import datetime as dt
import json
import os
import re
import subprocess
from collections import defaultdict
from pathlib import Path
from typing import Any

import requests
from openpyxl import load_workbook
from urllib.parse import quote


WORKSPACE = Path("/root/.openclaw/workspace")
FILLIN = WORKSPACE / "secure/api-fillin.env"
VENV_XLS_PY = WORKSPACE / ".venv-xls/bin/python"


def load_env() -> dict[str, str]:
    d = {}
    if not FILLIN.exists():
        raise SystemExit(f"missing {FILLIN}")
    for line in FILLIN.read_text(encoding="utf-8", errors="ignore").splitlines():
        if not line or line.strip().startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        d[k.strip()] = v.strip()
    need = ["NEXTCLOUD_URL", "NEXTCLOUD_USER", "NEXTCLOUD_PASS", "ERP_BASE_URL", "ERP_API_TOKEN"]
    miss = [k for k in need if k not in d or not d[k]]
    if miss:
        raise SystemExit(f"missing keys in {FILLIN}: {miss}")
    return d


def dav_url(base: str, user: str, rel: str, is_dir: bool = False) -> str:
    parts = [quote(p) for p in rel.strip("/").split("/") if p]
    url = base.rstrip("/") + "/remote.php/dav/files/" + quote(user) + "/" + "/".join(parts)
    return url + ("/" if is_dir else "")


def dav_get(session: requests.Session, base: str, user: str, rel: str, dst: Path):
    url = dav_url(base, user, rel, is_dir=False)
    r = session.get(url, timeout=120)
    r.raise_for_status()
    dst.parent.mkdir(parents=True, exist_ok=True)
    dst.write_bytes(r.content)


def dav_put(session: requests.Session, base: str, user: str, rel: str, src: Path):
    url = dav_url(base, user, rel, is_dir=False)
    data = src.read_bytes()
    r = session.put(url, data=data, timeout=120)
    r.raise_for_status()


def extract_detail_csv(period: str, xls_path: Path, out_csv: Path):
    script = WORKSPACE / "skills/jizhong-reconcile-workbook/scripts/extract_finance_xls.py"
    if not VENV_XLS_PY.exists():
        raise SystemExit(f"missing xlrd venv python: {VENV_XLS_PY}")

    cmd = [str(VENV_XLS_PY), str(script), "--xls", str(xls_path), "--period", period, "--out", str(out_csv)]
    subprocess.run(cmd, check=True)


def is_no_invoice_bill_no(bill_no: Any) -> bool:
    """Treat bill_no like 0 / 00 / 00/00000 as 'no invoice'.

    Rules:
    - empty/None => no invoice
    - if all digits in the string are zeros => no invoice
    """
    if bill_no is None:
        return True
    s = str(bill_no).strip()
    if s == "":
        return True
    digits = re.sub(r"\D+", "", s)
    if digits and set(digits) == {"0"}:
        return True
    return False


def fetch_invoices(session: requests.Session, erp_base: str, erp_token: str, company: str, start: str, end: str) -> list[dict[str, Any]]:
    headers = {"Authorization": f"token {erp_token}"}

    # list
    url = erp_base.rstrip("/") + "/api/resource/Purchase Invoice"
    filters = [["company", "=", company], ["posting_date", "between", [start, end]], ["docstatus", "=", 1]]
    fields = ["name"]
    r = session.get(url, headers=headers, params={"filters": json.dumps(filters, ensure_ascii=False), "fields": json.dumps(fields, ensure_ascii=False), "limit_page_length": 1000}, timeout=60)
    r.raise_for_status()
    names = [x["name"] for x in r.json().get("data", [])]

    docs = []
    for name in names:
        r2 = session.get(erp_base.rstrip("/") + f"/api/resource/Purchase Invoice/{name}", headers=headers, timeout=60)
        r2.raise_for_status()
        docs.append(r2.json()["data"])
    return docs


def score_invoice(v_date: str, v_amount: float, inv: dict[str, Any]) -> int:
    s = 0
    gt = float(inv.get("grand_total") or 0)
    if abs(gt - v_amount) < 1e-6:
        s += 50
    elif abs(gt - v_amount) <= 2.0:
        s += 35
    elif abs(gt - v_amount) <= 10.0:
        s += 15

    if v_date and inv.get("posting_date"):
        try:
            d0 = dt.date.fromisoformat(v_date)
            d1 = dt.date.fromisoformat(inv["posting_date"])
            dd = abs((d1 - d0).days)
            if dd == 0:
                s += 20
            elif dd <= 2:
                s += 10
            elif dd <= 7:
                s += 5
        except Exception:
            pass

    return s


def normalize_sheet_name(name: str) -> str:
    """Make sheet matching robust to minor naming diffs.

    Examples:
    - '03应付账款' -> '应付账款'
    - '银行'/'银行存款' -> '银行'
    - '现金'/'现金账' -> '现金'

    NOTE: keeps strict to user rule: only '应付账款' (not 其他应付款/职工薪酬).
    """
    s = str(name or "").strip()
    s = re.sub(r"^[\s0-9._-]+", "", s)
    if "银行" in s:
        return "银行"
    if "现金" in s and "没有发票" not in s:
        return "现金"
    if "应付账款" in s and "明细" not in s:
        return "应付账款"
    return s


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--company", default="天津吉众科技有限公司")
    ap.add_argument("--period", required=True, help="YYYYMM")
    ap.add_argument("--remote-dir", required=True, help="Nextcloud path under user root")
    ap.add_argument("--finance-xls", required=True, help="filename under remote-dir")
    ap.add_argument("--template", default=str(WORKSPACE / "skills/jizhong-reconcile-workbook/assets/匹配模板.xlsx"))
    ap.add_argument("--tol", type=float, default=2.0, help="invoice amount tolerance")
    args = ap.parse_args()

    env = load_env()
    nc_base = env["NEXTCLOUD_URL"].rstrip("/")
    nc_user = env["NEXTCLOUD_USER"]
    nc_pass = env["NEXTCLOUD_PASS"]

    erp_base = env["ERP_BASE_URL"].rstrip("/")
    erp_token = env["ERP_API_TOKEN"]

    if not Path(args.template).exists():
        raise SystemExit(f"template not found: {args.template}")

    period = args.period
    if len(period) != 6 or not period.isdigit():
        raise SystemExit("--period must be YYYYMM")
    year = int(period[:4])
    month = int(period[4:6])
    start = f"{year:04d}-{month:02d}-01"
    # end as last day of month
    if month == 12:
        end_date = dt.date(year + 1, 1, 1) - dt.timedelta(days=1)
    else:
        end_date = dt.date(year, month + 1, 1) - dt.timedelta(days=1)
    end = end_date.isoformat()

    dav_sess = requests.Session()
    dav_sess.auth = (nc_user, nc_pass)

    erp_sess = requests.Session()

    work_dir = WORKSPACE / "secure/finance/reconcile_runs" / period
    work_dir.mkdir(parents=True, exist_ok=True)

    finance_xls_local = work_dir / args.finance_xls
    try:
        dav_get(dav_sess, nc_base, nc_user, f"{args.remote_dir}/{args.finance_xls}", finance_xls_local)
    except Exception as e:
        # Nextcloud 偶发不可达时：允许使用本地缓存继续生成（不阻塞对账推进）
        if finance_xls_local.exists() and finance_xls_local.stat().st_size > 0:
            print(f"WARN: dav_get failed, using local cached finance xls: {finance_xls_local} ({e})")
        else:
            raise

    detail_csv = work_dir / f"detail_all_lines_{period}.csv"
    extract_detail_csv(period, finance_xls_local, detail_csv)

    # load detail lines
    lines = []
    with open(detail_csv, encoding="utf-8") as f:
        r = csv.DictReader(f)
        for row in r:
            # normalize sheet name for robust matching (keep original for debugging)
            row["sheet_raw"] = row.get("sheet")
            row["sheet"] = normalize_sheet_name(row.get("sheet") or "")

            for k in ["debit", "credit", "balance"]:
                row[k] = float(row[k] or 0)
            lines.append(row)

    def compute_open_close(sheet: str) -> tuple[float | None, float | None]:
        first = None
        last = None
        for row in lines:
            if row.get("sheet") != sheet:
                continue
            if first is None:
                first = row
            last = row
        if first is None:
            return None, None
        # balance evolves as: new_balance = old_balance + debit - credit
        opening = round(float(first.get("balance") or 0) - float(first.get("debit") or 0) + float(first.get("credit") or 0), 2)
        closing = round(float(last.get("balance") or 0), 2)
        return opening, closing

    bank_open, bank_close = compute_open_close("银行")
    cash_open, cash_close = compute_open_close("现金")

    by_v = defaultdict(list)
    for row in lines:
        by_v[row["voucher"]].append(row)

    # fetch invoices + split: 有发票 / 无发票
    inv_docs = fetch_invoices(erp_sess, erp_base, erp_token, args.company, start, end)
    inv_with_bill = [d for d in inv_docs if not is_no_invoice_bill_no(d.get("bill_no"))]
    inv_no_bill = [d for d in inv_docs if is_no_invoice_bill_no(d.get("bill_no"))]

    # build voucher-level finance rows
    finance_bank = []
    finance_cash = []
    finance_ap = []  # 应付（仅 A=0 的应付凭证）
    finance_by_voucher = {}  # voucher -> (finance_name, B)
    finance_kind_by_voucher: dict[str, str] = {}  # voucher -> kind (ap_only/bank_direct/bank_payment/...)

    for v, lst in by_v.items():
        bank_out = sum(r["credit"] for r in lst if r["sheet"] == "银行")
        cash_out = sum(r["credit"] for r in lst if r["sheet"] == "现金")
        ap_only = sum(r["credit"] for r in lst if r["sheet"] == "应付账款" and r["credit"] > 0)

        has_out = (bank_out + cash_out) > 1e-6
        has_ap = ap_only > 1e-6

        # 三类凭证：银行出账 / 现金出账 / 仅应付（A=0）
        if (not has_out) and (not has_ap):
            continue
        # 注意：现实中可能同一凭证同时包含“银行/现金出账 + 应付账款贷方”(部分付款/部分挂应付)
        # 该场景下：
        # - 凭证仍进入银行/现金表（A>0），B 仍用于勾稽发票总额
        # - 同时把“同凭证应付贷方”单独展示出来（不再丢弃）

        v_date = ""
        for r in lst:
            if r["sheet"] in ("银行", "现金") and r.get("date"):
                v_date = r["date"]
                break
        if not v_date:
            for r in lst:
                if r["sheet"] == "应付账款" and r.get("date"):
                    v_date = r["date"]
                    break

        # 摘要：优先取银行/现金的“出账行”(credit>0) 的摘要，其次取首个非空摘要；若仍为空则回退到应付摘要
        v_summary = ""
        for r in lst:
            if r["sheet"] in ("银行", "现金") and (r.get("summary") or "").strip() and float(r.get("credit") or 0) > 0:
                v_summary = (r.get("summary") or "").strip()
                break
        if not v_summary:
            for r in lst:
                if r["sheet"] in ("银行", "现金") and (r.get("summary") or "").strip():
                    v_summary = (r.get("summary") or "").strip()
                    break
        if not v_summary:
            for r in lst:
                if r["sheet"] == "应付账款" and (r.get("summary") or "").strip():
                    v_summary = (r.get("summary") or "").strip()
                    break

        debit_non = sum(r["debit"] for r in lst if r["sheet"] not in ("银行", "现金") and r["debit"] > 0)
        # 注意：用户口径——“财务应付”只包含 应付账款(2202)
        ap_credit_raw = sum(r["credit"] for r in lst if r["sheet"] == "应付账款" and r["credit"] > 0)
        # 付款类凭证通常表现为：借 应付账款 + （可能）借 手续费；贷 银行/现金
        ap_debit = sum(r["debit"] for r in lst if r["sheet"] == "应付账款" and r["debit"] > 0)

        # 用户澄清：会计的财务“银行/现金账”里，既然已电汇/现金支付，就不需要再“挂应付”。
        # 因此：当同一凭证存在银行/现金出账(A>0)时，不把应付计入银行/现金匹配口径，也不展示挂应付。
        ap_credit = 0.0 if has_out else ap_credit_raw

        # 手续费（电汇/网银等）：优先按科目识别；识别不到时，再用“小额借方”兜底（只在同凭证存在大额主营借方时触发）
        fee_debit = sum(
            r["debit"]
            for r in lst
            if (r.get("subject_code", "").startswith("560302") or r["sheet"] == "财务费用") and r["debit"] > 0
        )
        if fee_debit <= 1e-6 and has_out:
            debits_non = [
                float(r.get("debit") or 0)
                for r in lst
                if r["sheet"] not in ("银行", "现金") and float(r.get("debit") or 0) > 0
            ]
            small = [d for d in debits_non if 0 < d <= 50]
            big = [d for d in debits_non if d > 50]
            bank_credit = float(bank_out + cash_out)
            # 仅当凭证形态接近“贷 银行/现金 = 非银行借方合计”时，才做兜底判断（避免误伤小额真实采购）
            if big and small and abs(bank_credit - sum(debits_non)) <= 0.05:
                fee_guess = sum(small)
                if fee_guess <= 100:
                    fee_debit = fee_guess

        fee_debit = round(float(fee_debit or 0), 2)

        # fee exclude rule: only exclude when there's other substance (non-fee debits or AP credit)
        fee_exclude = fee_debit if ((debit_non - fee_debit) > 1e-6 or ap_credit > 1e-6) else 0.0

        B = (debit_non - fee_exclude)
        if B <= 1e-6:
            B = (bank_out + cash_out + ap_credit - fee_exclude)
        if B <= 1e-6:
            B = (bank_out + cash_out)
        B = round(B, 2)

        A = round(bank_out + cash_out, 2)

        suffix = v.replace("记-", "")
        if has_ap and (not has_out):
            fn = f"应付-{suffix}"
            A0 = 0.0
            # 对“仅应付”的凭证，B 以应付贷方为准（更稳定）；若为空再用 B 兜底
            B_ap = round(ap_credit, 2) if ap_credit > 1e-6 else B
            finance_ap.append([v_date, fn, v_summary, B_ap, B_ap, A0, round(fee_debit, 2), 0.0, None])
            finance_by_voucher[v] = (fn, B_ap)
            finance_kind_by_voucher[v] = "ap_only"
        elif bank_out > 0 and cash_out <= 0:
            fn = f"银行-{suffix}"
            ap_mix = round(float(ap_credit_raw or 0), 2) if ap_credit_raw > 1e-6 else 0.0
            finance_bank.append([v_date, fn, v_summary, B, B, A, round(fee_debit, 2), ap_mix, None])
            finance_by_voucher[v] = (fn, B)
            finance_kind_by_voucher[v] = "bank_payment" if ap_debit > 1e-6 else "bank_direct"
        elif cash_out > 0 and bank_out <= 0:
            fn = f"现金-{suffix}"
            ap_mix = round(float(ap_credit_raw or 0), 2) if ap_credit_raw > 1e-6 else 0.0
            finance_cash.append([v_date, fn, v_summary, B, B, A, round(fee_debit, 2), ap_mix, None])
            finance_by_voucher[v] = (fn, B)
            finance_kind_by_voucher[v] = "cash_payment" if ap_debit > 1e-6 else "cash_direct"
        else:
            # rare: both present; split by actual
            fn1 = f"银行-{suffix}"
            fn2 = f"现金-{suffix}"
            bank_summary = ""
            for r in lst:
                if r["sheet"] == "银行" and (r.get("summary") or "").strip() and float(r.get("credit") or 0) > 0:
                    bank_summary = (r.get("summary") or "").strip()
                    break
            if not bank_summary:
                bank_summary = v_summary

            cash_summary = ""
            for r in lst:
                if r["sheet"] == "现金" and (r.get("summary") or "").strip() and float(r.get("credit") or 0) > 0:
                    cash_summary = (r.get("summary") or "").strip()
                    break
            if not cash_summary:
                cash_summary = v_summary

            ap_mix = round(float(ap_credit_raw or 0), 2) if ap_credit_raw > 1e-6 else 0.0
            finance_bank.append([v_date, fn1, bank_summary, round(bank_out, 2), round(bank_out, 2), round(bank_out, 2), round(fee_debit, 2), ap_mix, None])
            finance_cash.append([v_date, fn2, cash_summary, round(cash_out, 2), round(cash_out, 2), round(cash_out, 2), 0.0, 0.0, None])
            finance_by_voucher[v] = (fn1, round(bank_out, 2))
            finance_kind_by_voucher[v] = "mixed_out"

    # auto-match voucher -> invoice(s) by B amount
    # - Supports 1 voucher -> N invoices (N<=3) when totals sum to B
    # - Conservative by default: exact/near-exact amount matching with small tolerance

    def extract_keywords(s: str) -> set[str]:
        if not s:
            return set()
        s = str(s)
        s = s.replace("*", " ")
        # keep only chinese/letters/digits for tokenization
        s = re.sub(r"[^0-9A-Za-z\u4e00-\u9fff]+", " ", s)
        kws = set(re.findall(r"[\u4e00-\u9fff]{2,}", s))
        return {k.strip() for k in kws if k.strip()}

    # build invoice meta cache
    inv_by_name: dict[str, dict[str, Any]] = {d.get("name"): d for d in inv_with_bill}
    inv_amount_cents: dict[str, int] = {}
    inv_text: dict[str, str] = {}
    for inv in inv_with_bill:
        nm = inv.get("name")
        if not nm:
            continue
        gt = round(float(inv.get("grand_total") or 0), 2)
        inv_amount_cents[nm] = int(round(gt * 100))
        parts: list[str] = []
        for x in [inv.get("bill_no"), inv.get("posting_date"), inv.get("supplier"), inv.get("remarks"), inv.get("custom_明细摘要")]:
            if x:
                parts.append(str(x))
        for it in inv.get("items", []) or []:
            for x in [it.get("item_name"), it.get("item_code"), it.get("custom_备注"), it.get("custom_guige_xinghao")]:
                if x:
                    parts.append(str(x))
        inv_text[nm] = " ".join(parts)

    # build voucher -> keyword set from all lines
    voucher_text: dict[str, str] = {}
    for v, lst in by_v.items():
        ss = []
        for r in lst:
            if (r.get("summary") or "").strip():
                ss.append((r.get("summary") or "").strip())
        voucher_text[v] = " ".join(ss)

    tol_cents = int(round(float(args.tol) * 100))

    ym_re = re.compile(r"(20\d{2})\s*年\s*(\d{1,2})\s*月")

    def extract_ym_tags(s: str) -> set[str]:
        if not s:
            return set()
        tags: set[str] = set()
        for y, m in ym_re.findall(str(s)):
            try:
                tags.add(f"{int(y):04d}-{int(m):02d}")
            except Exception:
                pass
        return tags

    def pick_best_combo(v: str, fn: str, B: float, v_date: str, available: set[str]) -> list[str]:
        Bc = int(round(round(float(B), 2) * 100))
        if Bc <= 0:
            return []

        # 金额优先：关键词只作为弱加分（tie-breaker），绝不当作硬过滤
        kws = extract_keywords(voucher_text.get(v, ""))

        def build_cands() -> list[tuple[str, int, int]]:
            out: list[tuple[str, int, int]] = []
            for nm in available:
                cents = inv_amount_cents.get(nm)
                if cents is None:
                    continue
                if cents <= 0 or cents > (Bc + tol_cents):
                    continue
                inv = inv_by_name.get(nm)
                if not inv:
                    continue
                sc = score_invoice(v_date, float(B), inv)
                if kws:
                    txt = inv_text.get(nm, "")
                    hits = sum(1 for k in kws if k in txt)
                    if hits:
                        sc += min(10, hits * 2)
                out.append((nm, cents, sc))
            # 优先金额接近，其次分数高
            out.sort(key=lambda x: (abs(x[1] - Bc), -x[2]))
            return out[:120]

        cands = build_cands()

        def one_invoice_match(cands: list[tuple[str, int, int]]) -> list[str]:
            best_nm = None
            best_score = -1
            best_gap = None
            for nm, cents, sc in cands:
                gap = abs(cents - Bc)
                if gap <= tol_cents:
                    if best_nm is None or gap < (best_gap or 10**18) or (gap == best_gap and sc > best_score):
                        best_nm = nm
                        best_score = sc
                        best_gap = gap
            return [best_nm] if best_nm else []

        picked = one_invoice_match(cands)
        if picked:
            return picked

        def try_sum_match(cands: list[tuple[str, int, int]]) -> list[str]:
            # 2-sum
            best = None
            best_gap = None
            best_score = -1
            n = len(cands)
            for i in range(n):
                nm1, c1, sc1 = cands[i]
                for j in range(i + 1, n):
                    nm2, c2, sc2 = cands[j]
                    s = c1 + c2
                    gap = abs(s - Bc)
                    if gap <= tol_cents:
                        sc = sc1 + sc2
                        if best is None or gap < best_gap or (gap == best_gap and sc > best_score):
                            best = [nm1, nm2]
                            best_gap = gap
                            best_score = sc
            if best:
                return best

            # 3-sum (pair-sum map)
            pair_map: dict[int, tuple[str, str, int]] = {}
            for i in range(n):
                nm1, c1, sc1 = cands[i]
                for j in range(i + 1, n):
                    nm2, c2, sc2 = cands[j]
                    s = c1 + c2
                    sc = sc1 + sc2
                    if s not in pair_map or sc > pair_map[s][2]:
                        pair_map[s] = (nm1, nm2, sc)

            best = None
            best_gap = None
            best_score = -1
            for nm3, c3, sc3 in cands:
                need = Bc - c3
                for ds in range(-tol_cents, tol_cents + 1):
                    key = need + ds
                    if key not in pair_map:
                        continue
                    nm1, nm2, sc12 = pair_map[key]
                    if nm1 == nm3 or nm2 == nm3:
                        continue
                    gap = abs((key + c3) - Bc)
                    sc = sc12 + sc3
                    if best is None or gap < best_gap or (gap == best_gap and sc > best_score):
                        best = [nm1, nm2, nm3]
                        best_gap = gap
                        best_score = sc
            return best or []

        return try_sum_match(cands)

    # main matching loop
    match_by_voucher: dict[str, list[str]] = {}
    available_invoices: set[str] = {d.get("name") for d in inv_with_bill if d.get("name")}

    # process vouchers in chronological order for stability
    v_items = []
    for v, (fn, B) in finance_by_voucher.items():
        # 付款类凭证（借应付贷银行/现金）不参与“发票基准”的主匹配；它们会写入“付款凭证(可多条)”列
        if finance_kind_by_voucher.get(v) in ("bank_payment", "cash_payment"):
            continue
        v_date = ""
        for row in finance_bank + finance_cash + finance_ap:
            if row[1] == fn:
                v_date = row[0]
                break
        v_items.append((v_date or "9999-99-99", v, fn, B))
    v_items.sort(key=lambda x: (x[0], x[1]))

    for v_date, v, fn, B in v_items:
        picked = pick_best_combo(v, fn, float(B), v_date, available_invoices)
        if picked:
            match_by_voucher[v] = picked
            for nm in picked:
                if nm in available_invoices:
                    available_invoices.remove(nm)

    # 付款凭证匹配：不占用发票主匹配名额；用于把“挂应付 + 已付款(可多笔)”都写回发票行
    fin_row_by_name: dict[str, list[Any]] = {row[1]: row for row in (finance_bank + finance_cash + finance_ap)}
    inv_pay_fns: dict[str, list[str]] = defaultdict(list)
    inv_pay_a: dict[str, float] = defaultdict(float)
    inv_pay_fee: dict[str, float] = defaultdict(float)

    pay_items = []
    for v, (fn, B) in finance_by_voucher.items():
        if finance_kind_by_voucher.get(v) not in ("bank_payment", "cash_payment"):
            continue
        v_date = ""
        row = fin_row_by_name.get(fn)
        if row:
            v_date = str(row[0] or "")
        pay_items.append((v_date or "9999-99-99", v, fn, float(B)))
    pay_items.sort(key=lambda x: (x[0], x[1]))

    all_invoices: set[str] = {d.get("name") for d in inv_with_bill if d.get("name")}

    for v_date, v, fn, B in pay_items:
        picked = pick_best_combo(v, fn, float(B), v_date, all_invoices)
        if not picked:
            continue
        # 基础门槛：金额必须在容差内；且至少有一个关键词命中（如果凭证摘要能提取到关键词）
        Bc = int(round(round(float(B), 2) * 100))
        sumc = sum(inv_amount_cents.get(nm, 0) for nm in picked)
        if abs(sumc - Bc) > tol_cents:
            continue

        # 关键词不作硬过滤，仅用于弱加分（金额优先）

        for inv_name in picked:
            inv_pay_fns[inv_name].append(fn)
            r = fin_row_by_name.get(fn)
            if r:
                inv_pay_a[inv_name] += float(r[5] or 0)
                inv_pay_fee[inv_name] += float(r[6] or 0)

    # compute allocations and remaining(B)
    alloc = defaultdict(float)
    inv_to_fin: dict[str, tuple[str, float]] = {}
    for v, inv_names in match_by_voucher.items():
        fn, B = finance_by_voucher[v]
        for inv_name in inv_names:
            gt = float(next((x.get("grand_total") for x in inv_docs if x.get("name") == inv_name), 0) or 0)
            gt = round(gt, 2)
            inv_to_fin[inv_name] = (fn, gt)
            alloc[fn] += gt

    for row in finance_bank:
        fn = row[1]
        B = row[3]
        row[4] = round(B - alloc.get(fn, 0.0), 2)
    for row in finance_cash:
        fn = row[1]
        B = row[3]
        row[4] = round(B - alloc.get(fn, 0.0), 2)

    for row in finance_ap:
        fn = row[1]
        B = row[3]
        row[4] = round(B - alloc.get(fn, 0.0), 2)

    finance_bank.sort(key=lambda x: (x[0] or "9999", x[1]))
    finance_cash.sort(key=lambda x: (x[0] or "9999", x[1]))
    finance_ap.sort(key=lambda x: (x[0] or "9999", x[1]))

    # build invoice rows (split)
    invoice_rows_yes: list[list[Any]] = []
    invoice_rows_no: list[list[Any]] = []

    # allocate bank/cash payments + fee proportionally when one finance voucher matches multiple invoices
    fin_row_by_name: dict[str, list[Any]] = {row[1]: row for row in (finance_bank + finance_cash + finance_ap)}

    inv_total: dict[str, float] = {inv.get("name"): round(float(inv.get("grand_total") or 0), 2) for inv in inv_with_bill if inv.get("name")}

    inv_bank_amt: dict[str, float] = defaultdict(float)  # 电汇金额（不含手续费）
    inv_bank_fee: dict[str, float] = defaultdict(float)  # 分摊手续费
    inv_cash_amt: dict[str, float] = defaultdict(float)  # 现金金额

    for v, inv_names in match_by_voucher.items():
        fn, _B = finance_by_voucher[v]
        r = fin_row_by_name.get(fn)
        if not r:
            continue
        A = float(r[5] or 0)
        fee = float(r[6] or 0)
        if A <= 1e-6:
            continue
        net = round(A - fee, 2)
        if net < 0:
            net = 0.0
        total_sum = sum(inv_total.get(nm, 0.0) for nm in inv_names) or 0.0
        if total_sum <= 1e-6:
            continue

        for nm in inv_names:
            wt = float(inv_total.get(nm, 0.0)) / total_sum
            if fn.startswith("银行-"):
                inv_bank_amt[nm] += net * wt
                inv_bank_fee[nm] += fee * wt
            elif fn.startswith("现金-"):
                inv_cash_amt[nm] += net * wt

    # round
    for d in (inv_bank_amt, inv_bank_fee, inv_cash_amt):
        for k in list(d.keys()):
            d[k] = round(float(d[k] or 0), 2)

    # Build per-invoice voucher lists (bank/cash/ap) so they can be shown together on the invoice row.
    inv_bank_fns: dict[str, set[str]] = defaultdict(set)
    inv_cash_fns: dict[str, set[str]] = defaultdict(set)
    inv_ap_fns: dict[str, set[str]] = defaultdict(set)

    for v, inv_names in match_by_voucher.items():
        fn, _B = finance_by_voucher[v]
        r = fin_row_by_name.get(fn)
        ap_mix = float(r[7] or 0) if (r and len(r) > 7) else 0.0
        for nm in inv_names:
            if fn.startswith("银行-"):
                inv_bank_fns[nm].add(fn)
                if ap_mix > 1e-6:
                    inv_ap_fns[nm].add(fn)
            elif fn.startswith("现金-"):
                inv_cash_fns[nm].add(fn)
                if ap_mix > 1e-6:
                    inv_ap_fns[nm].add(fn)
            elif fn.startswith("应付-"):
                inv_ap_fns[nm].add(fn)

    def _append_invoice_rows(inv: dict[str, Any], dest: list[list[Any]]):
        inv_name = inv.get("name")
        inv_date = inv.get("posting_date") or ""
        bill_no = inv.get("bill_no") or ""
        inv_remark = (inv.get("custom_明细摘要") or inv.get("remarks") or "")

        bank_vouchers = ";".join(sorted(inv_bank_fns.get(inv_name) or []))
        cash_vouchers = ";".join(sorted(inv_cash_fns.get(inv_name) or []))
        ap_vouchers = ";".join(sorted(inv_ap_fns.get(inv_name) or []))

        total = round(float(inv.get("grand_total") or 0), 2)
        bank_amt = float(inv_bank_amt.get(inv_name, 0.0) or 0.0)
        bank_fee = float(inv_bank_fee.get(inv_name, 0.0) or 0.0)
        cash_amt = float(inv_cash_amt.get(inv_name, 0.0) or 0.0)
        remain_ap = round(total - bank_amt - cash_amt, 2) if total > 0 else ""

        # 为避免在“明细行”里重复计数：只在该发票的第一行写这些汇总列，后续行留空
        wrote_summary = False

        for it in inv.get("items", []) or []:
            item_name = it.get("item_name") or it.get("item_code") or ""
            spec = it.get("custom_guige_xinghao") or ""
            rate = float(it.get("rate") or 0)
            qty = float(it.get("qty") or 0)
            uom = it.get("uom") or ""
            amount = float(it.get("amount") or 0)
            item_remark = it.get("custom_备注") or ""
            remark = item_remark if item_remark else inv_remark

            if not wrote_summary:
                row_bank_vs = bank_vouchers or ""
                row_cash_vs = cash_vouchers or ""
                row_ap_vs = ap_vouchers or ""

                row_bank_amt = round(bank_amt, 2) if bank_amt > 1e-6 else ""
                row_bank_fee = round(bank_fee, 2) if bank_fee > 1e-6 else ""
                row_cash_amt = round(cash_amt, 2) if cash_amt > 1e-6 else ""
                row_remain = remain_ap if isinstance(remain_ap, float) and abs(remain_ap) > 1e-6 else (0.0 if total > 0 else "")
                wrote_summary = True
            else:
                row_bank_vs = ""
                row_cash_vs = ""
                row_ap_vs = ""
                row_bank_amt = ""
                row_bank_fee = ""
                row_cash_amt = ""
                row_remain = ""

            dest.append(
                [
                    inv_name,
                    inv_date,
                    bill_no,
                    item_name,
                    spec,
                    rate,
                    qty,
                    uom,
                    amount,
                    row_bank_vs,
                    row_bank_amt,
                    row_bank_fee,
                    row_cash_vs,
                    row_cash_amt,
                    row_ap_vs,
                    row_remain,
                    remark,
                ]
            )

    for inv in inv_with_bill:
        _append_invoice_rows(inv, invoice_rows_yes)
    for inv in inv_no_bill:
        _append_invoice_rows(inv, invoice_rows_no)


    # build income (入账) rows: bank/cash debits on 银行/现金 sheet
    bank_income = []
    cash_income = []
    income_csv_rows = []

    for v, lst in by_v.items():
        bank_in = sum(r["debit"] for r in lst if r["sheet"] == "银行")
        cash_in = sum(r["debit"] for r in lst if r["sheet"] == "现金")
        if bank_in <= 0 and cash_in <= 0:
            continue

        v_date = ""
        v_summary = ""
        for r in lst:
            if r["sheet"] in ("银行", "现金") and r.get("date"):
                v_date = r["date"]
            if r["sheet"] in ("银行", "现金") and (r.get("summary") or "").strip():
                v_summary = (r.get("summary") or "").strip()
            if v_date and v_summary:
                break

        suffix = v.replace("记-", "")
        if bank_in > 0:
            name = f"银行收入-{suffix}"
            bank_income.append([v_date, name, round(bank_in, 2), v_summary])
            income_csv_rows.append({"date": v_date, "voucher": v, "type": "bank", "name": name, "amount_in": round(bank_in, 2), "summary": v_summary})
        if cash_in > 0:
            name = f"现金收入-{suffix}"
            cash_income.append([v_date, name, round(cash_in, 2), v_summary])
            income_csv_rows.append({"date": v_date, "voucher": v, "type": "cash", "name": name, "amount_in": round(cash_in, 2), "summary": v_summary})

    bank_income.sort(key=lambda x: (x[0] or "9999", x[2]))
    cash_income.sort(key=lambda x: (x[0] or "9999", x[2]))

    # opening/closing balances (上期结转/期末结转) for 银行/现金
    def open_close(sheet: str) -> tuple[float | None, float | None]:
        first = None
        last = None
        for r in lines:
            if r.get("sheet") == sheet and r.get("date"):
                first = r
                break
        for r in reversed(lines):
            if r.get("sheet") == sheet and r.get("date"):
                last = r
                break
        if not first or not last:
            return None, None
        opening = round(float(first["balance"]) - float(first["debit"]) + float(first["credit"]), 2)
        closing = round(float(last["balance"]), 2)
        return opening, closing

    bank_open, bank_close = open_close("银行")
    cash_open, cash_close = open_close("现金")
    headers_balance = ["类别", "上期结转余额", "期末结转余额", "期间"]
    balance_rows = [
        ["银行", bank_open, bank_close, period],
        ["现金", cash_open, cash_close, period],
    ]

    # fill workbook
    headers_fin = [
        "财务日期",
        "财务记账名",
        "摘要",
        "支出金额(B凭证口径)",
        "剩余匹配金额(B)",
        "支出金额(A银行出账)",
        "手续费",
        "同凭证应付(贷方)",
        "结转余额(核对)",
    ]
    headers_inv = [
        "发票单号",
        "单据日期",
        "发票号",
        "物料名",
        "规格",
        "单价",
        "数量",
        "单位",
        "总金额",
        "银行凭证(可多条)",
        "财务电汇金额",
        "电汇手续费",
        "现金凭证(可多条)",
        "财务现金金额",
        "应付凭证(可多条)",
        "剩余应付金额",
        "备注",
    ]
    # 应付账款匹配（用于“无现金/银行出账但已挂应付”的场景）
    ap_rows = []
    for v, lst in by_v.items():
        ap_credit_only = sum(r["credit"] for r in lst if r["sheet"] == "应付账款")
        if ap_credit_only <= 1e-6:
            continue
        ap_date = ""
        ap_summary = ""
        for r in lst:
            if r["sheet"] == "应付账款" and r.get("date"):
                ap_date = r["date"]
            if r["sheet"] == "应付账款" and (r.get("summary") or "").strip():
                ap_summary = (r.get("summary") or "").strip()
            if ap_date and ap_summary:
                break

        bank_out = sum(r["credit"] for r in lst if r["sheet"] == "银行")
        cash_out = sum(r["credit"] for r in lst if r["sheet"] == "现金")
        out_a = round(bank_out + cash_out, 2)

        # 用户规则：应付账单不可能同时有银行/现金出账；因此只保留 A=0 的应付
        if out_a > 1e-6:
            continue

        # match to Purchase Invoice by amount+date
        best = None
        best_sc = -1
        for inv in inv_with_bill:
            # 优先只在“未付”发票里匹配应付（更符合应付含义）
            if float(inv.get("outstanding_amount") or 0) <= 1e-6:
                continue
            sc = score_invoice(ap_date, round(ap_credit_only, 2), inv)
            if sc > best_sc:
                best_sc = sc
                best = inv

        # fallback: 若未付发票里完全匹配不到，再放宽到“有发票号”的所有发票
        if best_sc < 35:
            for inv in inv_with_bill:
                sc = score_invoice(ap_date, round(ap_credit_only, 2), inv)
                if sc > best_sc:
                    best_sc = sc
                    best = inv
        if best_sc < 35:
            best = None

        if best:
            ap_rows.append([
                ap_date,
                v,
                ap_summary,
                round(ap_credit_only, 2),
                out_a,
                best.get("name") or "",
                best.get("posting_date") or "",
                best.get("supplier") or "",
                best.get("bill_no") or "",
                float(best.get("grand_total") or 0),
                float(best.get("outstanding_amount") or 0),
                best_sc,
            ])
        else:
            ap_rows.append([ap_date, v, ap_summary, round(ap_credit_only, 2), out_a, "", "", "", "", "", "", best_sc])

    ap_rows.sort(key=lambda x: (x[0] or "9999", x[1]))

    headers_income = ["财务日期", "财务记账名", "入账金额", "摘要"]
    headers_ap = ["财务日期", "财务凭证号", "摘要", "应付金额(贷方)", "同凭证银行/现金出账(A)", "匹配发票单号", "单据日期", "供应商", "发票号", "发票金额", "未付金额", "匹配评分"]

    wb = load_workbook(Path(args.template))

    def clear_after_header(ws, header_row=1):
        if ws.max_row > header_row:
            ws.delete_rows(header_row + 1, ws.max_row - header_row)

    # ensure sheets exist
    for name in [
        "财务现金",
        "财务银行",
        "财务应付",
        "财务银行入账",
        "财务现金入账",
        "发票基准",
        "无发票支出",
        "余额汇总",
    ]:
        if name not in wb.sheetnames:
            wb.create_sheet(name)

    ws_cash = wb["财务现金"]
    for j, h in enumerate(headers_fin, start=1):
        ws_cash.cell(1, j, value=h)
    clear_after_header(ws_cash)

    # 用户最新要求：不在财务工作表里写“上期结转/本期结转”行（避免和收入缺失导致的理解混乱）
    for i, row in enumerate(finance_cash, start=2):
        for j, v in enumerate(row, start=1):
            ws_cash.cell(i, j, value=v)

    ws_bank = wb["财务银行"]
    for j, h in enumerate(headers_fin, start=1):
        ws_bank.cell(1, j, value=h)
    clear_after_header(ws_bank)

    for i, row in enumerate(finance_bank, start=2):
        for j, v in enumerate(row, start=1):
            ws_bank.cell(i, j, value=v)

    # remove legacy sheet (user request: no standalone 应付账单匹配 sheet)
    if "应付账单匹配" in wb.sheetnames:
        wb.remove(wb["应付账单匹配"])

    ws_ap_fin = wb["财务应付"]
    for j, h in enumerate(headers_fin, start=1):
        ws_ap_fin.cell(1, j, value=h)
    clear_after_header(ws_ap_fin)
    for i, row in enumerate(finance_ap, start=2):
        for j, v in enumerate(row, start=1):
            ws_ap_fin.cell(i, j, value=v)

    ws_bi = wb["财务银行入账"]
    for j, h in enumerate(headers_income, start=1):
        ws_bi.cell(1, j, value=h)
    clear_after_header(ws_bi)
    for i, row in enumerate(bank_income, start=2):
        for j, v in enumerate(row, start=1):
            ws_bi.cell(i, j, value=v)

    ws_ci = wb["财务现金入账"]
    for j, h in enumerate(headers_income, start=1):
        ws_ci.cell(1, j, value=h)
    clear_after_header(ws_ci)
    for i, row in enumerate(cash_income, start=2):
        for j, v in enumerate(row, start=1):
            ws_ci.cell(i, j, value=v)

    ws_inv = wb["发票基准"]
    for j, h in enumerate(headers_inv, start=1):
        ws_inv.cell(1, j, value=h)
    clear_after_header(ws_inv)
    for i, row in enumerate(invoice_rows_yes, start=2):
        for j, v in enumerate(row, start=1):
            ws_inv.cell(i, j, value=v)

    ws_noinv = wb["无发票支出"]
    for j, h in enumerate(headers_inv, start=1):
        ws_noinv.cell(1, j, value=h)
    clear_after_header(ws_noinv)
    for i, row in enumerate(invoice_rows_no, start=2):
        for j, v in enumerate(row, start=1):
            ws_noinv.cell(i, j, value=v)

    ws_bal = wb["余额汇总"]
    for j, h in enumerate(headers_balance, start=1):
        ws_bal.cell(1, j, value=h)
    clear_after_header(ws_bal)
    for i, row in enumerate(balance_rows, start=2):
        for j, v in enumerate(row, start=1):
            ws_bal.cell(i, j, value=v)

    out_name = f"匹配模板_{period}_自动填充_v21_AB_含规格备注_含入账_含余额_含应付_含财务应付_拆分无票_发票含电汇手续费_财务表删凭证号_不含结转行.xlsx"
    out_local = work_dir / out_name
    wb.save(out_local)

    # income csv
    income_csv = work_dir / f"bank_cash_income_{period}.csv"
    if income_csv_rows:
        with open(income_csv, "w", newline="", encoding="utf-8") as f:
            w = csv.DictWriter(f, fieldnames=["date", "voucher", "type", "name", "amount_in", "summary"])
            w.writeheader()
            w.writerows(income_csv_rows)

    # upload (best-effort)
    uploaded = False
    try:
        dav_put(dav_sess, nc_base, nc_user, f"{args.remote_dir}/{out_name}", out_local)
        if income_csv.exists():
            dav_put(dav_sess, nc_base, nc_user, f"{args.remote_dir}/{income_csv.name}", income_csv)
        uploaded = True
    except Exception as e:
        print(f"WARN: dav_put failed, kept local output only: {e}")

    if uploaded:
        print(f"OK: uploaded {out_name} (+ income csv) -> {args.remote_dir}/")
    else:
        print(f"OK: generated locally: {out_local}")


if __name__ == "__main__":
    main()
